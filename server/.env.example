PORT=5000

# Choose database type: 'mongodb' or 'postgres'
DB_TYPE=mongodb

# Database Connection URLs
# For MongoDB, e.g., mongodb://localhost:27017/creatoros or mongodb+srv://...
DATABASE_URL=mongodb://localhost:27017/creatoros
# For PostgreSQL, e.g., postgresql://username:password@localhost:5432/creatoros
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creatoros

JWT_SECRET=supersecretjwtkeyforcreatoros2026

# Cloudinary Credentials (for profile image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
